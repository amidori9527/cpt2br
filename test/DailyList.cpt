<?xml version="1.0" encoding="UTF-8"?>
<WorkBook xmlVersion="20211223" releaseVersion="11.0.0">
<TableDataMap>
<TableData name="病人住院费用清单-主" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="dtMedcgB"/>
<O>
<![CDATA[2020-11-03]]></O>
</Parameter>
<Parameter>
<Attributes name="dtMedcgE"/>
<O>
<![CDATA[2022-11-30]]></O>
</Parameter>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'6114d21c032e3d5968fbfd58\']]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[SELECT
     TO_char(HI_BIL_MED_CG_IP.dt_medcg, 'YYYY-MM-DD') as "医疗记退费日期",
	HI_VIS_MED.ID_VISMED AS "医疗就诊流程",
	HI_VIS_MED.ID_ORG AS "机构",
	HI_VIS_MED.na_pi AS "病人姓名",
	HI_VIS_MED.id_hipl_main AS "保险计划",
	HI_VIS_MED_IP.cd_vismed as "住院号码",
  HI_VIS_MED_IP.CD_BED as "病人床号",
  HI_VIS_MED.id_dep_clin as "病人科室",
  to_char(HI_VIS_MED.dt_vismed_b,'YYYY-MM-DD') as "入院日期", 
  CASE WHEN trunc(nvl(dt_vismed_e,sysdate)-dt_vismed_b, 0)=0 THEN 1 WHEN trunc(nvl(dt_vismed_e,sysdate)-dt_vismed_b, 0)=1 THEN 1ELSE trunc(nvl(dt_vismed_e,sysdate)-dt_vismed_b, 0) END as "住院天数",
  to_char(HI_VIS_MED.dt_vismed_e,'YYYY-MM-DD') as "出院日期",
  -- HI_VIS_MED_IP_BL.amt_ipcost as "费用累计",
  HI_BIL_MED_CG_IP.total_amt_srv * (HI_BIL_MED_CG_IP.eu_direct) as "费用累计",
  HI_VIS_MED_IP_BL.amt_deposit+HI_VIS_MED_IP_BL.amt_piacct as "总预交金"
FROM
	HI_VIS_MED
LEFT JOIN HI_VIS_MED_IP ON HI_VIS_MED.ID_VISMED = HI_VIS_MED_IP.ID_VISMED
LEFT JOIN HI_VIS_MED_IP_BL ON HI_VIS_MED.ID_VISMED = HI_VIS_MED_IP_BL.ID_VISMED
LEFT JOIN HI_BIL_MED_CG_IP ON HI_VIS_MED.ID_VISMED = HI_BIL_MED_CG_IP.ID_VISMED
 WHERE
	HI_VIS_MED.ID_VISMED in(${idVismed})
AND HI_BIL_MED_CG_IP.dt_medcg BETWEEN TO_DATE('${dtMedcgB}', 'YYYY-MM-DD hh24:mi:ss')
AND TO_DATE('${dtMedcgE}', 'YYYY-MM-DD hh24:mi:ss')
AND HI_BIL_MED_CG_IP.fg_medst_canc_c=0
order by HI_VIS_MED.ID_VISMED,HI_BIL_MED_CG_IP.dt_medcg,HI_VIS_MED.na_pi]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="病人住院费用清单-明细" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="dtMedcgB"/>
<O>
<![CDATA[2019-01-01]]></O>
</Parameter>
<Parameter>
<Attributes name="dtMedcgE"/>
<O>
<![CDATA[2020-02-28]]></O>
</Parameter>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'5e4c9fcee915790cf43fdcba\',\'5cb6855ac33ef043f8eae536\',\'5e241ea76c078c0c30ed83b8\']]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[SELECT
  HI_BIL_MED_CG_IP.ID_VISMED AS "医疗就诊流程",
  TO_char(HI_BIL_MED_CG_IP.dt_medcg, 'YYYY-MM-DD') as "医疗记退费日期",
  TO_char(HI_BIL_MED_CG_IP.dt_medcg, 'hh24:mi') as "医疗记退费时间",
  HI_BIL_MED_CG_IP.na_srv as "项目名称",
  HI_BIL_MED_CG_IP_PD.spec_pd as "规格",
  HI_BIL_MED_CG_IP.quan_srv * (HI_BIL_MED_CG_IP.eu_direct) as "数量",
  HI_BIL_MED_CG_IP.unit_srv_med as "单位",
  HI_BIL_MED_CG_IP.price_srv as "价格",
  HI_BIL_MED_CG_IP.total_amt_srv * (HI_BIL_MED_CG_IP.eu_direct) as "金额",
  HI_BIL_MED_CG_IP.amt_srv_pi * (HI_BIL_MED_CG_IP.eu_direct) as "自理",
  MAP_DEP_NA(HI_BIL_MED_CG_IP.id_dep_medcg_exc) as "归属部门",
  TO_char(HI_BIL_MED_CG_IP.dt_med, 'MM-DD hh24:mi') as "费用日期"
FROM
  HI_BIL_MED_CG_IP 
LEFT JOIN HI_BIL_MED_CG_IP_PD ON HI_BIL_MED_CG_IP.id_medcgip = HI_BIL_MED_CG_IP_PD.id_medcgip
WHERE
 HI_BIL_MED_CG_IP.ID_VISMED in(${idVismed})
 AND HI_BIL_MED_CG_IP.dt_medcg BETWEEN TO_DATE('${dtMedcgB}', 'YYYY-MM-DD hh24:mi:ss')
 AND TO_DATE('${dtMedcgE}', 'YYYY-MM-DD hh24:mi:ss')+1
 AND HI_BIL_MED_CG_IP.fg_medst_canc_c=0
order by
  HI_BIL_MED_CG_IP.ID_VISMED,
  HI_BIL_MED_CG_IP.dt_medcg,
  HI_BIL_MED_CG_IP.dt_med,
  HI_BIL_MED_CG_IP.na_srv]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
