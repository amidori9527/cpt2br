<?xml version="1.0" encoding="UTF-8"?>
<WorkBook xmlVersion="20170720" releaseVersion="10.0.0">
<TableDataMap>
<TableData name="信息栏数据(只取一行)" class="com.fr.data.impl.DBTableData">
<Parameters>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'66c42cbf67b26400156311be\',\'66f3a2db0a86f1001541070c\']]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[SELECT
	med.na_Pi AS 病人姓名,
	hipl.na as 病人性质,
	med.dt_vismed_b AS 入院日期,
	stIp.amt_medst_pi as 自理自费,
	pi.cd_pi AS 住院号码,
	dep.na AS 病人科室,
	med.dt_vismed_e AS 出院日期,
	stIp.amt_medst as 费用总额,
	med.id_org as 机构,
	med.sd_sex AS 病人性别,
	DECODE(TO_DATE(TO_CHAR(nvl(med.dt_vismed_e,SYSDATE),'YYYYMMDD'),'YYYYMMDD') - TO_DATE(TO_CHAR(med.dt_vismed_b,'YYYYMMDD'),'YYYYMMDD'),'0','1',TO_DATE(TO_CHAR(nvl(med.dt_vismed_e,SYSDATE),'YYYYMMDD'),'YYYYMMDD') - TO_DATE(TO_CHAR(med.dt_vismed_b,'YYYYMMDD'),'YYYYMMDD')) 
	AS 住院天数，
	hipl.na as 保险计划,
	bl.amt_ipcost as 费用累计,
	(nvl(bl.amt_deposit,0)+nvl(bl.amt_piacct,0)) as 预交金额,
 	stIp.amt_medst_pi as 个人支付金额,
 	pi.cd_pi as 住院号码
FROM
	hi_Vis_Med med
	LEFT JOIN HI_VIS_MED_IP ip ON med.id_vismed = ip.id_vismed
	LEFT JOIN HI_BD_HIPL hipl ON med.ID_HIPL_MAIN = hipl.ID_HIPL
	LEFT JOIN HI_VIS_MED_IP_BL bl ON bl.id_vismed = ip.id_vismed
	left join HI_BIL_MED_ST_IP stIp ON stIp.id_vismed = med.id_vismed
	left join hi_pi pi on pi.id_pi = med.id_Pi  
	left join hi_sys_dep@DBLINKBBP dep on dep.id_dep=med.id_dep_clin
where 
	med.id_vismed in (${idVismed})
	and rownum = 1]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="病人床号" class="com.fr.data.impl.DBTableData">
<Parameters>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'61cac3cb2c73335f428db095\']]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[select 
 bdbed.cd
from 
  hi_vis_med med
left join
   HI_VIS_MED_BED bed
on 
  bed.id_vismed = med.id_vismed

left join hi_bd_bed bdbed
on 
bdbed.id_bed=bed.id_bed
where 
bed.fg_bed_main= '1'
and med.id_vismed in (${idVismed})
and rownum = 1
order by bed.insert_time desc]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="自理自费对应预结自负，费用总额对应总费用（重新查询）" class="com.fr.data.impl.DBTableData">
<Parameters>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'5cb6855ac33ef043f8eae532\']]></O>
</Parameter>
<Parameter>
<Attributes name="dateStart"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="dateEnd"/>
<O>
<![CDATA[]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[select 
	sum(cgip.TOTAL_AMT_SRV * cgip.eu_direct) as 费用总额,
	sum(cgip.amt_srv_pi * cgip.eu_direct) as 自理自费
from 
	hi_bil_med_cg_ip cgip 
where 
	cgip.fg_medst_canc_c= '0'
and 
	cgip.delete_flag = '0'
and 	
	cgip.id_vismed in (${idVismed})
and cgip.dt_medcg >=  to_date('${dateStart}:00', 'yyyy-mm-dd,hh24:mi:ss')
and cgip.dt_medcg <=  to_date('${dateEnd}:59', 'yyyy-mm-dd,hh24:mi:ss')
]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
