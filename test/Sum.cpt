<TableData name="账卡归并" class="com.fr.data.impl.DBTableData">
<Parameters>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'6413cf578e205f0001bc197b\']]></O>
</Parameter>
<Parameter>
<Attributes name="dateStart"/>
<O>
<![CDATA[2023-03-17]]></O>
</Parameter>
<Parameter>
<Attributes name="dateEnd"/>
<O>
<![CDATA[2023-05-17]]></O>
</Parameter>
<Parameter>
<Attributes name="idDep"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="sdSrvtpCd"/>
<O>
<![CDATA[]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[with usdca as
         (select itm.NA, itm.CD, itm.ID_USDCAITM, itm.ID_PAR, lk.sd_srvcasrv_cd, lk.id_itmlk,lk.EU_DIRECT, usdca.ID_USDCA
          from HI_BD_USDCA_ITM_LK lk
                   left join HI_BD_USDCA_ITM itm on itm.ID_USDCAITM = lk.ID_USDCAITM and itm.DELETE_FLAG = '0'
                   left join HI_BD_USDCA usdca on usdca.ID_USDCA = itm.ID_USDCA and usdca.DELETE_FLAG = '0'
          where usdca.NA = '住院、门诊费用统计'
            and lk.DELETE_FLAG = '0'),
     cgip as (
         select cgip.id_medcgip,
                cgip.dt_medcg,
                cgip.id_dep_medcg_ord,
                cgip.id_les_medcg_ord,
                cgip.id_dep_medcg_exc,
                cgip.id_emp_medcg_ord,
                cgip.NA_SRV,
                cgip.PRICE_SRV,
                cgip.QUAN_SRV* cgip.EU_DIRECT as QUAN_SRV,
                cgip.TOTAL_AMT_SRV * cgip.EU_DIRECT as TOTAL_AMT_SRV,
								case when cgip.TOTAL_AMT_SRV=0 then 1 else cgip.amt_srv_pi/cgip.TOTAL_AMT_SRV end as self,
                cgip.sd_source_medcg_cd,
                cgip.ID_SRVCA,
                cgip.ID_SRV,
			cgip.amt_srv_pi* cgip.EU_DIRECT as amt_srv_pi,
                vismed.id_dep_grp_med,
                vismed.NA_PI,
                vismedip.NUM_VISMED,
                vismedip.CD_VISMED,
                vismed.ID_VISMED
         from HI_BIL_MED_CG_IP cgip
                  left join HI_VIS_MED vismed on vismed.ID_VISMED = cgip.ID_VISMED and vismed.SD_VISTP_CD = '114'
                  left join HI_VIS_MED_IP vismedip on vismedip.ID_VISMED = cgip.ID_VISMED
         where cgip.DELETE_FLAG = '0'
           and cgip.FG_MEDST_CANC_C = '0'
           ${if(len(idDep)=0,"","and cgip.id_dep_medcg_exc = '"+idDep+"'")}
${IF( LEN ( sdSrvtpCd ) != 0, " and cgip.sd_srvtp_cd like " + "'" + sdSrvtpCd + "%'", "" ) } 
					 and cgip.dt_medcg >=  to_date('${dateStart}:00', 'yyyy-mm-dd,hh24:mi:ss')
					 and cgip.dt_medcg <=  to_date('${dateEnd}:59', 'yyyy-mm-dd,hh24:mi:ss')
     )
select to_char(ci.self,'fm9999990.00') as self,
       ci."NA_SRV",
       to_char(ci."PRICE_SRV",'fm9999990.00') as PRICE_SRV,
       to_char(sum(ci."QUAN_SRV"),'fm9999990.00') as QUAN_SRV,
			 to_char(sum(ci."AMT_SRV_PI"),'fm9999990.00') as AMT_SRV_PI,
      to_char(sum(ci."TOTAL_AMT_SRV" * NVl(NVL(u1."EU_DIRECT", u2."EU_DIRECT"),'1')),'fm9999990.00') AS "TOTAL_AMT_SRV",
       NVL(u1."NA",u2."NA") AS NA
       
from cgip ci
         left join usdca u1 on ( u1.ID_ITMLK = ci.ID_SRVCA)
         LEFT JOIN usdca u2 on ( u2.ID_ITMLK = ci.ID_SRV)
				 where ci.ID_VISMED in (${idVismed})
				 GROUP BY ci."NA_SRV",
       ci."PRICE_SRV",
			 ci.self,
			 NVL(u1."NA",u2."NA")]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
