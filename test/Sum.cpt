<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[SELECT
	med.na_Pi AS 病人姓名
FROM
	hi_Vis_Med med
	LEFT JOIN HI_VIS_MED_IP ip ON med.id_vismed = ip.id_vismed
	LEFT JOIN HI_BD_HIPL hipl ON med.ID_HIPL_MAIN = hipl.ID_HIPL
	LEFT JOIN HI_VIS_MED_IP_BL bl ON bl.id_vismed = ip.id_vismed
	left join HI_BIL_MED_ST_IP stIp ON stIp.id_vismed = med.id_vismed
	left join hi_pi pi on pi.id_pi = med.id_Pi  
	left join hi_sys_dep@DBLINKBBP dep on dep.id_dep=med.id_dep_clin
where 
	med.id_vismed in (${idVismed})
	]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
