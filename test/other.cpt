<?xml version="1.0" encoding="UTF-8"?>
<WorkBook xmlVersion="20211223" releaseVersion="10.0.0">
<TableDataMap>
<TableData name="表格数据" class="com.fr.data.impl.DBTableData">
<Parameters>
<Parameter>
<Attributes name="dateStart"/>
<O>
<![CDATA[2021-08-20]]></O>
</Parameter>
<Parameter>
<Attributes name="sdSrvtpCd"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="dateEnd"/>
<O>
<![CDATA[2021-09-15]]></O>
</Parameter>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'6103d24f032e3d5e952e1e17\']]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[SELECT
	CONCAT(CONCAT(na_srv, '/'),unit_srv_med) AS 项目名称,
	sum( quan_srv * eu_direct ) AS 数量,
	max(price_srv) AS 价格,
	sum( ( quan_srv * eu_direct ) * price_srv ) AS 总金额,
	sum( eu_direct * amt_srv_pi ) AS 患者自负,
	id_dep_medcg_exc AS 归属科室
FROM
	HI_BIL_MED_CG_IP 
WHERE
	delete_flag = '0'		--删除标志
	and fg_medst_canc_c = '0'		--取消结算作废标志
	AND id_vismed IN ( ${idVismed} ) --医疗就诊流程id
	and dt_med BETWEEN to_date( '${dateStart}', 'YYYY-MM-DD' ) 
	AND to_date('${dateEnd}', 'YYYY-MM-DD' )+1		

--服务项目类型
${IF(LEN(sdSrvtpCd) != 0," and sd_srvtp_cd like " + "'" + sdSrvtpCd + "%'", "")}	

group by unit_srv_med,na_srv,id_dep_medcg_exc
order by na_srv asc]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="病人信息" class="com.fr.data.impl.DBTableData">
<Parameters>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'5ea54c61eb49850ffcdfbdc2\']]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[SELECT
	med.na_Pi AS 病人姓名,
	ip.cd_bed AS 病人床号,
	med.sd_sex AS 病人性别,
	ip.cd_vismed AS 病案号,
	id_dep_clin AS 病人科室,
	to_char(med.dt_vismed_b, 'yyyy-mm-dd' ) AS 入院日期,
	to_char(med.dt_vismed_e, 'yyyy-mm-dd' ) AS 出院日期,
	DECODE(TO_DATE(TO_CHAR(nvl(med.dt_vismed_e,SYSDATE),'YYYYMMDD'),'YYYYMMDD') - TO_DATE(TO_CHAR(med.dt_vismed_b,'YYYYMMDD'),'YYYYMMDD'),'0','1',TO_DATE(TO_CHAR(nvl(med.dt_vismed_e,SYSDATE),'YYYYMMDD'),'YYYYMMDD') - TO_DATE(TO_CHAR(med.dt_vismed_b,'YYYYMMDD'),'YYYYMMDD')) 
	AS 住院天数，
	hipl.na as 保险计划,
	bl.amt_ipcost as 未结费用,
	bl.amt_iptotal as 累计费用,
	bl.amt_prej_me as 预结自付,
	med.id_org as 机构id
FROM
	hi_Vis_Med med
	LEFT JOIN HI_VIS_MED_IP ip ON med.id_vismed = ip.id_vismed
	LEFT JOIN HI_BD_HIPL hipl ON med.ID_HIPL_MAIN = hipl.ID_HIPL
	LEFT JOIN HI_VIS_MED_IP_BL bl ON bl.id_vismed = ip.id_vismed
where 
	med.id_vismed in (${idVismed})]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="患者支付查询" class="com.fr.data.impl.DBTableData">
<Parameters>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'5cb6855ac33ef043f8eae532\']]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[select sum(t.amt_medst_pi) as 个人支付金额
  from HI_BIL_MED_ST_IP t
 where t.id_vismed in (${idVismed})	--医疗就诊流程
   and  t.fg_medst_canc != '1'	--医疗结算取消标志]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
