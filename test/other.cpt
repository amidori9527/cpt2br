<TableData name="表格查询（新）" class="com.fr.data.impl.DBTableData">
<Parameters>
<Parameter>
<Attributes name="dateStart"/>
<O>
<![CDATA[2021-08-18]]></O>
</Parameter>
<Parameter>
<Attributes name="sdSrvtpCd"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="dateEnd"/>
<O>
<![CDATA[2022-06-17]]></O>
</Parameter>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'611cd5be032e3d61c9bf72dd\']]></O>
</Parameter>
<Parameter>
<Attributes name="idOrg"/>
<O>
<![CDATA[5e1c2d2b6c078c10a0599172]]></O>
</Parameter>
<Parameter>
<Attributes name="idDep"/>
<O>
<![CDATA[]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[with test as (
SELECT
	CONCAT(CONCAT(na_srv, '/'),unit_srv_med) AS 项目名称,
	sum( quan_srv * eu_direct ) AS 数量,
	max(price_srv) AS 价格,
	sum( ( quan_srv * eu_direct ) * price_srv ) AS 总金额,
	sum( eu_direct * amt_srv_pi ) AS 患者自负,
	id_dep_medcg_exc AS 归属科室,
	MAP_org_NA(id_org) as 机构名称,
	id_org as 机构,
	MAP_DEP_NA(id_dep_medcg_exc) AS 部门名称
FROM
	HI_BIL_MED_CG_IP 
WHERE
	delete_flag = '0'		--删除标志
	and fg_medst_canc_c = '0'		--取消结算作废标志
	AND id_vismed IN ( ${idVismed} ) --医疗就诊流程id
	and dt_med BETWEEN to_date( substr('${dateStart}',1,10), 'YYYY-MM-DD' ) 
	AND to_date(substr('${dateEnd}',1,10), 'YYYY-MM-DD' )+1		
${if(len(idDep)=0,"","and id_dep_medcg_exc = '"+idDep+"'")}
--服务项目类型
${IF(LEN(sdSrvtpCd) != 0," and sd_srvtp_cd like " + "'" + sdSrvtpCd + "%'", "")}	

group by unit_srv_med,na_srv,id_dep_medcg_exc,id_org
order by na_srv asc
) 
select 
		项目名称,
		数量,
		价格,
		总金额,
		归属科室,
		部门名称,
		${IF(LEN(idOrg)== 0," 部门名称 AS 新部门, "," ( case when 机构 = '"+idOrg+"' then 部门名称 else CONCAT( CONCAT( CONCAT( 部门名称, '(' ), 机构名称 ),')' ) end ) AS 新部门,")}
		患者自负
from test t order by 项目名称 asc]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="累计费用，预结自负重新计算" class="com.fr.data.impl.DBTableData">
<Parameters>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'628b2bf0032e3d73ad6d74e7\']]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[select 
	sum(cgip.TOTAL_AMT_SRV * cgip.eu_direct) as 累计费用,
	sum(cgip.amt_srv_pi * cgip.eu_direct) as 预结自负
from 
	hi_bil_med_cg_ip cgip 
where 
	cgip.fg_medst_canc_c= '0'
and 
	cgip.delete_flag = '0'
and 	
	cgip.id_vismed in (${idVismed})]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="未结费用重新计算" class="com.fr.data.impl.DBTableData">
<Parameters>
<Parameter>
<Attributes name="idVismed"/>
<O>
<![CDATA[\'628b2bf0032e3d73ad6d74e7\']]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[hisOracle]]></DatabaseName>
</Connection>
<Query>
<![CDATA[select 
	sum(cgip.TOTAL_AMT_SRV * cgip.eu_direct) as 未结费用
from	
	hi_bil_med_cg_ip cgip 
where 
	cgip.fg_medst_canc_c= '0'
and 
	cgip.delete_flag = '0'
and 
	cgip.fg_medcg = '0'  -- 表示尚未结算
and 	
	cgip.id_vismed in (${idVismed})]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
